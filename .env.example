# ===== Gemini (Google AI Studio 無料枠) =====
# https://aistudio.google.com/app/apikey で取得（無料）
GEMINI_API_KEY=your_gemini_api_key_here
# 無料枠の実測（このプロジェクトのキーで確認）:
#   gemini-2.5-flash-lite … 量産向け（推奨）。1記事≒3コール。
#   gemini-2.5-flash      … 高品質だが無料枠が1日20リクエストと極端に少ない
#   gemini-2.0-flash      … 無料枠対象外(limit 0)で使えない
GEMINI_MODEL=gemini-2.5-flash-lite

# ===== WordPress (REST API / アプリケーションパスワード) =====
# WP管理画面 > ユーザー > プロフィール > アプリケーションパスワード で発行
WP_BASE_URL=https://amaviser.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# 下書きで保存(draft) / 即公開(publish) / 公開予約(future)
WP_DEFAULT_STATUS=draft

# ===== もしもアフィリエイト =====
# もしもには公開APIが無いため、デフォルトの「かんたんリンク」HTMLを使うか、
# 商品ごとに手動で貼り付ける。下はリンク未取得時に挿入するプレースホルダ。
MOSHIMO_PLACEHOLDER=<!-- START MoshimoAffiliateEasyLink -->\nリンク\n<!-- MoshimoAffiliateEasyLink END -->

# もしもの成果ID（かんたんリンクHTMLの自動生成に使用 / Issue #8）
# かんたんリンクのソース内 "a_id":XXXXXXX の数値。
# ※自前生成の運用がもしもの規約上問題ないかは利用者が確認すること。
MOSHIMO_AID=

# 楽天ウェブサービス（新OpenAPI / 商品検索API・無料）
# https://webservice.rakuten.co.jp/ でアプリ登録して発行。
# 新仕様(2026-04-01)は applicationId(UUID形式) と accessKey(pk_...) の両方が必要。
RAKUTEN_APP_ID=                 # アプリケーションID（UUID形式）
RAKUTEN_ACCESS_KEY=             # アクセスキー（pk_ で始まる値）
RAKUTEN_AFFILIATE_ID=           # 任意。収益はもしも経由のため通常は空でよい

# ===== IndexNow（Bing/Yandex等への即時インデックス通知 / Issue #17）=====
# `python index_submit.py --setup` で生成・設置できる
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=

# ===== キュー（取り上げ商品リスト / Issue #32）=====
# Googleスプレッドシートを「ファイル→共有→ウェブに公開→CSV」で公開し、そのURLを設定。
# 設定するとバッチはこのシートを読む（レビュー担当がブラウザで商品を追記できる）。
# 未設定なら data/queue.csv を使う。
QUEUE_SHEET_CSV_URL=

# ===== アプリ =====
APP_HOST=127.0.0.1
APP_PORT=8000
